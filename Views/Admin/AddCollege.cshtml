@model InterviewCracker.Models.College

@{
    ViewData["Title"] = "Add College";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>
                <i class="fas fa-university text-primary"></i>
                Add New College
            </h2>
            <a href="@Url.Action("ManageColleges")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Manage Colleges
            </a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="fas fa-school"></i>
                    College Information
                </h5>
            </div>
            <div class="card-body">
                <form asp-action="AddCollege" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <!-- College Name -->
                    <div class="form-group">
                        <label asp-for="Name" class="form-label font-weight-bold">
                            <i class="fas fa-building"></i> College Name *
                        </label>
                        <input asp-for="Name" class="form-control" placeholder="Enter college name">
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <!-- Description -->
                    <div class="form-group">
                        <label asp-for="Description" class="form-label font-weight-bold">
                            <i class="fas fa-align-left"></i> Description
                        </label>
                        <textarea asp-for="Description" class="form-control" rows="3" 
                                  placeholder="Brief description about the college..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                        <small class="form-text text-muted">Optional: Provide a brief description of the college</small>
                    </div>

                    <!-- Location -->
                    <div class="form-group">
                        <label asp-for="Location" class="form-label font-weight-bold">
                            <i class="fas fa-map-marker-alt"></i> Location
                        </label>
                        <input asp-for="Location" class="form-control" placeholder="City, State">
                        <span asp-validation-for="Location" class="text-danger"></span>
                        <small class="form-text text-muted">City and State where the college is located</small>
                    </div>

                    <!-- Image Options -->
                    <div class="form-group">
                        <label class="form-label font-weight-bold">
                            <i class="fas fa-image"></i> College Image
                        </label>
                        
                        <!-- Image Upload Tabs -->
                        <ul class="nav nav-tabs" id="imageTab" role="tablist">
                            <li class="nav-item" role="presentation">
                                <a class="nav-link active" id="upload-tab" data-toggle="tab" href="#upload" role="tab" aria-controls="upload" aria-selected="true">
                                    <i class="fas fa-upload"></i> Upload Image
                                </a>
                            </li>
                            <li class="nav-item" role="presentation">
                                <a class="nav-link" id="url-tab" data-toggle="tab" href="#url" role="tab" aria-controls="url" aria-selected="false">
                                    <i class="fas fa-link"></i> Image URL
                                </a>
                            </li>
                        </ul>
                        
                        <div class="tab-content" id="imageTabContent">
                            <!-- Upload Tab -->
                            <div class="tab-pane fade show active" id="upload" role="tabpanel" aria-labelledby="upload-tab">
                                <div class="mt-3">
                                    <input type="file" id="imageFile" name="imageFile" class="form-control-file" accept="image/*" onchange="handleImageUpload(this)">
                                    <small class="form-text text-muted">
                                        <i class="fas fa-info-circle"></i> Upload a college logo or image (JPG, PNG, GIF - Max 5MB)
                                    </small>
                                    <div id="uploadProgress" class="progress mt-2" style="display: none;">
                                        <div class="progress-bar" role="progressbar" style="width: 0%"></div>
                                    </div>
                                    <div id="uploadStatus" class="mt-2"></div>
                                </div>
                            </div>
                            
                            <!-- URL Tab -->
                            <div class="tab-pane fade" id="url" role="tabpanel" aria-labelledby="url-tab">
                                <div class="mt-3">
                                    <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" onchange="updatePreviewFromUrl()">
                                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                                    <small class="form-text text-muted">
                                        <i class="fas fa-info-circle"></i> Enter a direct URL to the college logo or image
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Guidelines -->
                    <div class="alert alert-info">
                        <h6><i class="fas fa-info-circle"></i> Guidelines:</h6>
                        <ul class="mb-0">
                            <li>College name should be unique and descriptive</li>
                            <li>Use official college names when possible</li>
                            <li>Location should include city and state/country</li>
                            <li>Image URL should point to a valid image (optional)</li>
                        </ul>
                    </div>

                    <!-- Preview Card -->
                    <div class="card bg-light mb-3" id="college-preview">
                        <div class="card-header">
                            <h6 class="mb-0"><i class="fas fa-eye"></i> Preview</h6>
                        </div>
                        <div class="card-body" id="preview-content">
                            <div class="row">
                                <div class="col-md-3">
                                    <img id="preview-image" src="/images/default-college.jpg" 
                                         class="img-fluid rounded shadow-sm" alt="College Image" 
                                         style="max-height: 100px; width: auto;">
                                </div>
                                <div class="col-md-9">
                                    <h5 id="preview-name" class="text-muted">College Name</h5>
                                    <p id="preview-description" class="text-muted">College description will appear here...</p>
                                    <small id="preview-location" class="text-muted">
                                        <i class="fas fa-map-marker-alt"></i> Location
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="form-group text-center">
                        <button type="submit" class="btn btn-primary btn-lg mr-3">
                            <i class="fas fa-save"></i> Add College
                        </button>
                        <a href="@Url.Action("ManageColleges")" class="btn btn-secondary btn-lg">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        $(document).ready(function() {
            // Real-time preview update
            function updatePreview() {
                const name = $('#Name').val().trim() || 'College Name';
                const description = $('#Description').val().trim() || 'College description will appear here...';
                const location = $('#Location').val().trim() || 'Location';
                const imageUrl = $('#ImageUrl').val().trim();
                
                $('#preview-name').text(name);
                $('#preview-description').text(description);
                $('#preview-location').html('<i class="fas fa-map-marker-alt"></i> ' + location);
                
                if (imageUrl) {
                    $('#preview-image').attr('src', imageUrl);
                    $('#preview-image').on('error', function() {
                        $(this).attr('src', '/images/default-college.jpg');
                    });
                } else {
                    $('#preview-image').attr('src', '/images/default-college.jpg');
                }
            }
            
            // Update preview on input change
            $('#Name, #Description, #Location, #ImageUrl').on('input', updatePreview);
            
            // Character counter for name
            $('#Name').on('input', function() {
                const maxLength = 100;
                const currentLength = $(this).val().length;
                const remaining = maxLength - currentLength;
                
                let counter = $(this).siblings('.char-counter');
                if (counter.length === 0) {
                    counter = $('<small class="char-counter text-muted"></small>');
                    $(this).after(counter);
                }
                
                counter.text(`${currentLength}/${maxLength} characters`);
                
                if (remaining < 20) {
                    counter.removeClass('text-muted').addClass('text-warning');
                }
                if (remaining < 0) {
                    counter.removeClass('text-warning').addClass('text-danger');
                }
            });
            
            // Form validation
            $('form').on('submit', function(e) {
                const name = $('#Name').val().trim();
                
                if (!name) {
                    e.preventDefault();
                    alert('Please enter the college name.');
                    $('#Name').focus();
                    return false;
                }
                
                if (name.length < 3) {
                    e.preventDefault();
                    alert('College name must be at least 3 characters long.');
                    $('#Name').focus();
                    return false;
                }
            });
            
            // Initialize preview
            updatePreview();
        });
        
        // Handle image upload
        function handleImageUpload(input) {
            if (input.files && input.files[0]) {
                const file = input.files[0];
                
                // Validate file size (5MB max)
                if (file.size > 5 * 1024 * 1024) {
                    alert('File size must be less than 5MB');
                    input.value = '';
                    return;
                }
                
                // Validate file type
                if (!file.type.match('image.*')) {
                    alert('Please select a valid image file');
                    input.value = '';
                    return;
                }
                
                // Show upload progress
                $('#uploadProgress').show();
                $('#uploadStatus').html('<div class="alert alert-info"><i class="fas fa-spinner fa-spin"></i> Preparing upload...</div>');
                
                // Create preview
                const reader = new FileReader();
                reader.onload = function(e) {
                    $('#preview-image').attr('src', e.target.result);
                    
                    // Simulate upload progress (in real implementation, this would be actual upload)
                    let progress = 0;
                    const interval = setInterval(function() {
                        progress += 10;
                        $('.progress-bar').css('width', progress + '%');
                        
                        if (progress >= 100) {
                            clearInterval(interval);
                            setTimeout(function() {
                                $('#uploadProgress').hide();
                                $('#uploadStatus').html('<div class="alert alert-success"><i class="fas fa-check"></i> Image ready for upload</div>');
                                
                                // Set the ImageUrl field to indicate file upload
                                $('#ImageUrl').val('UPLOAD:' + file.name);
                            }, 500);
                        }
                    }, 100);
                };
                reader.readAsDataURL(file);
            }
        }
        
        // Handle URL input update
        function updatePreviewFromUrl() {
            const imageUrl = $('#ImageUrl').val().trim();
            if (imageUrl && !imageUrl.startsWith('UPLOAD:')) {
                $('#preview-image').attr('src', imageUrl);
                $('#preview-image').on('error', function() {
                    $(this).attr('src', '/images/default-college.jpg');
                });
            }
        }
        
        // Tab switching handlers
        $('#imageTab a').on('click', function (e) {
            e.preventDefault();
            $(this).tab('show');
            
            // Clear the other input when switching tabs
            if ($(this).attr('href') === '#upload') {
                $('#ImageUrl').val('');
            } else {
                $('#imageFile').val('');
                $('#uploadStatus').html('');
                $('#uploadProgress').hide();
            }
        });
    </script>
}