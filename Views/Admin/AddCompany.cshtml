@model InterviewCracker.Models.Company

@{
    ViewData["Title"] = "Add Company";
}

<!-- Success/Error Messages -->
@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["Message"]
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>
                <i class="fas fa-building text-primary"></i>
                Add New Company
            </h2>
            <a href="@Url.Action("ManageCompanies")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Manage Companies
            </a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="fas fa-building"></i>
                    Company Information
                </h5>
            </div>
            <div class="card-body">
                <form asp-action="AddCompany" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <!-- Company Name -->
                    <div class="form-group">
                        <label asp-for="Name" class="form-label font-weight-bold">
                            <i class="fas fa-building"></i> Company Name *
                        </label>
                        <input asp-for="Name" class="form-control" placeholder="Enter company name">
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <!-- Description -->
                    <div class="form-group">
                        <label asp-for="Description" class="form-label font-weight-bold">
                            <i class="fas fa-align-left"></i> Description
                        </label>
                        <textarea asp-for="Description" class="form-control" rows="3" 
                                  placeholder="Brief description about the company..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                        <small class="form-text text-muted">Optional: Provide a brief description of the company</small>
                    </div>

                    <!-- Website -->
                    <div class="form-group">
                        <label asp-for="Website" class="form-label font-weight-bold">
                            <i class="fas fa-globe"></i> Website
                        </label>
                        <input asp-for="Website" class="form-control" placeholder="https://company.com">
                        <span asp-validation-for="Website" class="text-danger"></span>
                        <small class="form-text text-muted">Company's official website URL</small>
                    </div>

                    <!-- Logo Options -->
                    <div class="form-group">
                        <label class="form-label font-weight-bold">
                            <i class="fas fa-image"></i> Company Logo
                        </label>
                        
                        <!-- Logo Upload Tabs -->
                        <ul class="nav nav-tabs" id="logoTab" role="tablist">
                            <li class="nav-item" role="presentation">
                                <a class="nav-link active" id="upload-tab" data-toggle="tab" href="#upload" role="tab" aria-controls="upload" aria-selected="true">
                                    <i class="fas fa-upload"></i> Upload Logo
                                </a>
                            </li>
                            <li class="nav-item" role="presentation">
                                <a class="nav-link" id="url-tab" data-toggle="tab" href="#url" role="tab" aria-controls="url" aria-selected="false">
                                    <i class="fas fa-link"></i> Logo URL
                                </a>
                            </li>
                        </ul>
                        
                        <div class="tab-content" id="logoTabContent">
                            <!-- Upload Tab -->
                            <div class="tab-pane fade show active" id="upload" role="tabpanel" aria-labelledby="upload-tab">
                                <div class="mt-3">
                                    <input type="file" id="logoFile" name="logoFile" class="form-control-file" accept="image/*" onchange="handleLogoUpload(this)">
                                    <small class="form-text text-muted">
                                        <i class="fas fa-info-circle"></i> Upload a company logo (JPG, PNG, GIF - Max 5MB)
                                    </small>
                                    <div id="uploadProgress" class="progress mt-2" style="display: none;">
                                        <div class="progress-bar" role="progressbar" style="width: 0%"></div>
                                    </div>
                                    <div id="uploadStatus" class="mt-2"></div>
                                </div>
                            </div>
                            
                            <!-- URL Tab -->
                            <div class="tab-pane fade" id="url" role="tabpanel" aria-labelledby="url-tab">
                                <div class="mt-3">
                                    <input asp-for="LogoUrl" class="form-control" placeholder="https://example.com/logo.jpg" onchange="updatePreviewFromUrl()">
                                    <span asp-validation-for="LogoUrl" class="text-danger"></span>
                                    <small class="form-text text-muted">
                                        <i class="fas fa-info-circle"></i> Enter a direct URL to the company logo
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Guidelines -->
                    <div class="alert alert-info">
                        <h6><i class="fas fa-info-circle"></i> Guidelines:</h6>
                        <ul class="mb-0">
                            <li>Company name should be unique and official</li>
                            <li>Description should be concise and informative</li>
                            <li>Website URL should include https:// or http://</li>
                            <li>Logo should be square format for best display</li>
                        </ul>
                    </div>

                    <!-- Preview Card -->
                    <div class="card bg-light mb-3" id="company-preview">
                        <div class="card-header">
                            <h6 class="mb-0"><i class="fas fa-eye"></i> Preview</h6>
                        </div>
                        <div class="card-body" id="preview-content">
                            <div class="row">
                                <div class="col-md-3">
                                    <img id="preview-logo" src="/images/default-company.jpg" 
                                         class="img-fluid rounded shadow-sm" alt="Company Logo" 
                                         style="max-height: 80px; width: auto;">
                                </div>
                                <div class="col-md-9">
                                    <h5 id="preview-name" class="text-muted">Company Name</h5>
                                    <p id="preview-description" class="text-muted">Company description will appear here...</p>
                                    <small id="preview-website" class="text-muted">
                                        <i class="fas fa-globe"></i> <a href="#" target="_blank">Website</a>
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="form-group text-center">
                        <button type="submit" class="btn btn-primary btn-lg mr-3">
                            <i class="fas fa-save"></i> Add Company
                        </button>
                        <a href="@Url.Action("ManageCompanies")" class="btn btn-secondary btn-lg">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        $(document).ready(function() {
            // Real-time preview update
            function updatePreview() {
                const name = $('#Name').val().trim() || 'Company Name';
                const description = $('#Description').val().trim() || 'Company description will appear here...';
                const website = $('#Website').val().trim() || '#';
                const logoUrl = $('#LogoUrl').val().trim();
                
                $('#preview-name').text(name);
                $('#preview-description').text(description);
                $('#preview-website a').attr('href', website).text(website || 'Website');
                
                if (logoUrl) {
                    $('#preview-logo').attr('src', logoUrl);
                    $('#preview-logo').on('error', function() {
                        $(this).attr('src', '/images/default-company.jpg');
                    });
                } else {
                    $('#preview-logo').attr('src', '/images/default-company.jpg');
                }
            }
            
            // Update preview on input change
            $('#Name, #Description, #Website, #LogoUrl').on('input', updatePreview);
            
            // Form validation
            $('form').on('submit', function(e) {
                const name = $('#Name').val().trim();
                
                if (!name) {
                    e.preventDefault();
                    alert('Please enter the company name.');
                    $('#Name').focus();
                    return false;
                }
                
                if (name.length < 2) {
                    e.preventDefault();
                    alert('Company name must be at least 2 characters long.');
                    $('#Name').focus();
                    return false;
                }
            });
            
            // Initialize preview
            updatePreview();
        });
        
        // Handle logo upload
        function handleLogoUpload(input) {
            if (input.files && input.files[0]) {
                const file = input.files[0];
                
                // Validate file size (5MB max)
                if (file.size > 5 * 1024 * 1024) {
                    alert('File size must be less than 5MB');
                    input.value = '';
                    return;
                }
                
                // Validate file type
                if (!file.type.match('image.*')) {
                    alert('Please select a valid image file');
                    input.value = '';
                    return;
                }
                
                // Show upload progress
                $('#uploadProgress').show();
                $('#uploadStatus').html('<div class="alert alert-info"><i class="fas fa-spinner fa-spin"></i> Preparing upload...</div>');
                
                // Create preview
                const reader = new FileReader();
                reader.onload = function(e) {
                    $('#preview-logo').attr('src', e.target.result);
                    
                    // Simulate upload progress
                    let progress = 0;
                    const interval = setInterval(function() {
                        progress += 10;
                        $('.progress-bar').css('width', progress + '%');
                        
                        if (progress >= 100) {
                            clearInterval(interval);
                            setTimeout(function() {
                                $('#uploadProgress').hide();
                                $('#uploadStatus').html('<div class="alert alert-success"><i class="fas fa-check"></i> Logo ready for upload</div>');
                                
                                // Set the LogoUrl field to indicate file upload
                                $('#LogoUrl').val('UPLOAD:' + file.name);
                            }, 500);
                        }
                    }, 100);
                };
                reader.readAsDataURL(file);
            }
        }
        
        // Handle URL input update
        function updatePreviewFromUrl() {
            const logoUrl = $('#LogoUrl').val().trim();
            if (logoUrl && !logoUrl.startsWith('UPLOAD:')) {
                $('#preview-logo').attr('src', logoUrl);
                $('#preview-logo').on('error', function() {
                    $(this).attr('src', '/images/default-company.jpg');
                });
            }
        }
        
        // Tab switching handlers
        $('#logoTab a').on('click', function (e) {
            e.preventDefault();
            $(this).tab('show');
            
            // Clear the other input when switching tabs
            if ($(this).attr('href') === '#upload') {
                $('#LogoUrl').val('');
            } else {
                $('#logoFile').val('');
                $('#uploadStatus').html('');
                $('#uploadProgress').hide();
            }
        });
    </script>
}