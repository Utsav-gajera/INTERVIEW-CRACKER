@model InterviewCracker.Models.User

@{
    ViewData["Title"] = "Add Contributor";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>
                <i class="fas fa-user-plus text-success"></i>
                Add New Contributor
            </h2>
            <a href="@Url.Action("ManageUsers")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Manage Users
            </a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">
                    <i class="fas fa-id-card"></i>
                    Contributor Information
                </h5>
            </div>
            <div class="card-body">
                <form asp-action="AddContributor" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <!-- Basic Information -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Name" class="form-label font-weight-bold">
                                    <i class="fas fa-user"></i> Full Name *
                                </label>
                                <input asp-for="Name" class="form-control" placeholder="Enter full name">
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Email" class="form-label font-weight-bold">
                                    <i class="fas fa-envelope"></i> Email Address *
                                </label>
                                <input asp-for="Email" type="email" class="form-control" placeholder="contributor@example.com">
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Password -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Password" class="form-label font-weight-bold">
                                    <i class="fas fa-lock"></i> Password *
                                </label>
                                <input asp-for="Password" type="password" class="form-control" placeholder="Enter password">
                                <span asp-validation-for="Password" class="text-danger"></span>
                                <small class="form-text text-muted">Minimum 6 characters</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="PhoneNumber" class="form-label font-weight-bold">
                                    <i class="fas fa-phone"></i> Phone Number
                                </label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="+1-234-567-8900">
                                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Organization -->
                    <div class="form-group">
                        <label asp-for="Organization" class="form-label font-weight-bold">
                            <i class="fas fa-building"></i> Organization/Company
                        </label>
                        <input asp-for="Organization" class="form-control" placeholder="Current organization or company">
                        <span asp-validation-for="Organization" class="text-danger"></span>
                        <small class="form-text text-muted">Optional: Current workplace or educational institution</small>
                    </div>

                    <!-- Bio -->
                    <div class="form-group">
                        <label asp-for="Bio" class="form-label font-weight-bold">
                            <i class="fas fa-user-edit"></i> Bio
                        </label>
                        <textarea asp-for="Bio" class="form-control" rows="3" 
                                  placeholder="Brief professional bio..."></textarea>
                        <span asp-validation-for="Bio" class="text-danger"></span>
                        <small class="form-text text-muted">Optional: Brief description about professional background</small>
                    </div>

                    <!-- Social Profiles -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="LinkedInProfile" class="form-label font-weight-bold">
                                    <i class="fab fa-linkedin"></i> LinkedIn Profile
                                </label>
                                <input asp-for="LinkedInProfile" class="form-control" placeholder="https://linkedin.com/in/username">
                                <span asp-validation-for="LinkedInProfile" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="GitHubProfile" class="form-label font-weight-bold">
                                    <i class="fab fa-github"></i> GitHub Profile
                                </label>
                                <input asp-for="GitHubProfile" class="form-control" placeholder="https://github.com/username">
                                <span asp-validation-for="GitHubProfile" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Role Information -->
                    <div class="alert alert-success">
                        <h6><i class="fas fa-info-circle"></i> Contributor Role:</h6>
                        <ul class="mb-0">
                            <li>Can add and edit MCQs and coding questions</li>
                            <li>All submissions require admin approval</li>
                            <li>Access to contributor dashboard and tools</li>
                            <li>Can view statistics of their contributions</li>
                        </ul>
                    </div>

                    <!-- Guidelines -->
                    <div class="alert alert-info">
                        <h6><i class="fas fa-clipboard-list"></i> Guidelines:</h6>
                        <ul class="mb-0">
                            <li>Use a valid and accessible email address</li>
                            <li>Password should be secure (minimum 6 characters)</li>
                            <li>Contributors will receive login credentials via email</li>
                            <li>All profile information can be updated later</li>
                        </ul>
                    </div>

                    <!-- Preview Card -->
                    <div class="card bg-light mb-3">
                        <div class="card-header">
                            <h6 class="mb-0"><i class="fas fa-eye"></i> Contributor Preview</h6>
                        </div>
                        <div class="card-body">
                            <div class="row align-items-center">
                                <div class="col-md-2">
                                    <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center" 
                                         style="width: 60px; height: 60px; font-size: 24px;">
                                        <i class="fas fa-user"></i>
                                    </div>
                                </div>
                                <div class="col-md-10">
                                    <h5 id="preview-name" class="mb-1">Contributor Name</h5>
                                    <p id="preview-email" class="text-muted mb-1">contributor@example.com</p>
                                    <p id="preview-organization" class="text-muted mb-1">
                                        <i class="fas fa-building"></i> Organization
                                    </p>
                                    <span class="badge badge-success">Contributor</span>
                                </div>
                            </div>
                            <div class="mt-3" id="preview-bio-section" style="display: none;">
                                <strong>Bio:</strong>
                                <p id="preview-bio" class="text-muted mb-0"></p>
                            </div>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="form-group text-center">
                        <button type="submit" id="submitBtn" class="btn btn-success btn-lg mr-3">
                            <span id="btn-text">
                                <i class="fas fa-user-plus"></i> Add Contributor
                            </span>
                            <span id="btn-loading" style="display: none;">
                                <i class="fas fa-spinner fa-spin"></i> Adding Contributor...
                            </span>
                        </button>
                        <a href="@Url.Action("ManageUsers")" class="btn btn-secondary btn-lg">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .form-label {
        margin-bottom: 0.3rem;
    }
    
    .card {
        border-radius: 10px;
    }
    
    .card-header {
        border-radius: 10px 10px 0 0 !important;
    }
    
    textarea.form-control {
        resize: vertical;
        min-height: 80px;
    }
    
    .alert {
        border-left: 4px solid;
        border-radius: 5px;
    }
    
    .alert-info {
        border-left-color: #17a2b8;
    }
    
    .alert-success {
        border-left-color: #28a745;
    }
    
    .btn-lg {
        padding: 0.75rem 2rem;
    }
    
    #submitBtn:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }
    
    .fa-spin {
        animation: spin 1s infinite linear;
    }
    
    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        $(document).ready(function() {
            var isSubmitting = false;

            // Update preview on input changes
            $('#Name').on('input', function() {
                var name = $(this).val() || 'Contributor Name';
                $('#preview-name').text(name);
            });

            $('#Email').on('input', function() {
                var email = $(this).val() || 'contributor@example.com';
                $('#preview-email').text(email);
            });

            $('#Organization').on('input', function() {
                var organization = $(this).val();
                if (organization) {
                    $('#preview-organization').html('<i class="fas fa-building"></i> ' + organization).show();
                } else {
                    $('#preview-organization').html('<i class="fas fa-building"></i> Organization');
                }
            });

            $('#Bio').on('input', function() {
                var bio = $(this).val();
                if (bio) {
                    $('#preview-bio').text(bio);
                    $('#preview-bio-section').show();
                } else {
                    $('#preview-bio-section').hide();
                }
            });

            // Form submission with loading state management
            $('form').on('submit', function(e) {
                // Prevent double submission
                if (isSubmitting) {
                    e.preventDefault();
                    return false;
                }

                var isValid = true;
                var email = $('#Email').val();
                var password = $('#Password').val();
                var name = $('#Name').val();

                // Clear previous errors
                clearAllErrors();

                // Check required fields
                if (!name.trim()) {
                    showFieldError('Name', 'Name is required');
                    isValid = false;
                }

                if (!email.trim()) {
                    showFieldError('Email', 'Email is required');
                    isValid = false;
                }

                if (!password.trim()) {
                    showFieldError('Password', 'Password is required');
                    isValid = false;
                } else if (password.length < 6) {
                    showFieldError('Password', 'Password must be at least 6 characters');
                    isValid = false;
                }

                if (!isValid) {
                    e.preventDefault();
                    resetSubmitButton();
                    $('html, body').animate({
                        scrollTop: $('.text-danger:visible').first().offset().top - 100
                    }, 500);
                    return false;
                }

                // If validation passes, show loading state
                showLoadingState();
                isSubmitting = true;
                
                // Let the form submit normally
                return true;
            });

            function showLoadingState() {
                $('#submitBtn').prop('disabled', true);
                $('#btn-text').hide();
                $('#btn-loading').show();
            }

            function resetSubmitButton() {
                $('#submitBtn').prop('disabled', false);
                $('#btn-text').show();
                $('#btn-loading').hide();
                isSubmitting = false;
            }

            function showFieldError(fieldName, message) {
                var field = $('#' + fieldName);
                var errorSpan = field.next('.text-danger');
                if (errorSpan.length === 0) {
                    errorSpan = $('<span class="text-danger"></span>');
                    field.after(errorSpan);
                }
                errorSpan.text(message);
                field.addClass('is-invalid');
            }

            function clearAllErrors() {
                $('.is-invalid').removeClass('is-invalid');
                $('.text-danger').text('');
            }

            // Clear validation errors on input and reset button if needed
            $('input, textarea').on('input', function() {
                $(this).removeClass('is-invalid');
                $(this).next('.text-danger').text('');
                
                // Reset button state if user starts typing after a validation error
                if (!isSubmitting) {
                    resetSubmitButton();
                }
            });

            // Reset button state if there are server-side validation errors on page load
            if ($('.text-danger').text().trim() !== '' || $('.alert-danger').length > 0) {
                resetSubmitButton();
            }
        });
    </script>
}
