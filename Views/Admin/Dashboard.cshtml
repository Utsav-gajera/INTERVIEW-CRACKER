@{
    ViewData["Title"] = "Admin Dashboard";
}

<!-- Dashboard Header -->
<div class="row mb-4">
    <div class="col-12">
        <div class="jumbotron bg-primary text-white">
            <h1 class="display-4">
                <i class="fas fa-tachometer-alt"></i> Admin Dashboard
            </h1>
            <p class="lead">Manage colleges, contributors, and oversee the entire platform.</p>
        </div>
    </div>
</div>

<!-- Statistics Cards -->
<div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card admin-card text-white">
            <div class="card-body admin-stat">
                <i class="fas fa-university"></i>
                <h2>@ViewBag.TotalColleges</h2>
                <p>Total Colleges</p>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card contributor-card text-white">
            <div class="card-body admin-stat">
                <i class="fas fa-users"></i>
                <h2>@ViewBag.TotalUsers</h2>
                <p>Total Users</p>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card text-white" style="background: linear-gradient(135deg, #f6c23e 0%, #dda20a 100%);">
            <div class="card-body admin-stat">
                <i class="fas fa-edit"></i>
                <h2>@ViewBag.TotalContributors</h2>
                <p>Contributors</p>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card text-white" style="background: linear-gradient(135deg, #e74a3b 0%, #c0392b 100%);">
            <div class="card-body admin-stat">
                <i class="fas fa-user-graduate"></i>
                <h2>@ViewBag.TotalStudents</h2>
                <p>Students</p>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-bolt"></i> Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <a href="@Url.Action("AddCollege", "Admin")" class="btn btn-primary btn-block">
                            <i class="fas fa-plus"></i> Add New College
                        </a>
                    </div>
                    <div class="col-md-3 mb-3">
                        <a href="@Url.Action("AddCompany", "Admin")" class="btn btn-success btn-block">
                            <i class="fas fa-plus"></i> Add New Company
                        </a>
                    </div>
                    <div class="col-md-3 mb-3">
                        <a href="@Url.Action("AddContributor", "Admin")" class="btn btn-success btn-block">
                            <i class="fas fa-user-plus"></i> Add Contributor
                        </a>
                    </div>
                    <div class="col-md-3 mb-3">
                        <a href="@Url.Action("ManageColleges", "Admin")" class="btn btn-warning btn-block">
                            <i class="fas fa-university"></i> Manage Colleges
                        </a>
                    </div>
                    <div class="col-md-3 mb-3">
                        <a href="@Url.Action("ManageCompanies", "Admin")" class="btn btn-warning btn-block">
                            <i class="fas fa-building"></i> Manage Companies
                        </a>
                    </div>
                    <div class="col-md-3 mb-3">
                        <a href="@Url.Action("ManageUsers", "Admin")" class="btn btn-info btn-block">
                            <i class="fas fa-users"></i> Manage Users
                        </a>
                    </div>
                    <div class="col-md-3 mb-3">
                        <a href="@Url.Action("AssignCompanyToCollege", "Admin")" class="btn btn-secondary btn-block">
                            <i class="fas fa-link"></i> Assign Company to College
                        </a>
                    </div>
                    <div class="col-md-3 mb-3">
                        <form asp-action="AutoApproveAllCodingQuestions" method="post" style="display: inline;">
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


