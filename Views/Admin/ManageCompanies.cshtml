@model List<InterviewCracker.Models.Company>

@{
    ViewData["Title"] = "Manage Companies";
}

<!-- Success/Error Messages -->
@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["Message"]
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>
                <i class="fas fa-building text-warning"></i>
                Manage Companies
            </h2>
            <a href="@Url.Action("AddCompany")" class="btn btn-primary">
                <i class="fas fa-plus"></i> Add New Company
            </a>
        </div>
    </div>
</div>

<!-- Statistics Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <i class="fas fa-building fa-2x mr-3"></i>
                    <div>
                        <h3 class="mb-0">@Model.Count()</h3>
                        <small>Total Companies</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <i class="fas fa-check-circle fa-2x mr-3"></i>
                    <div>
                        <h3 class="mb-0">@Model.Count(c => c.IsActive)</h3>
                        <small>Active Companies</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <i class="fas fa-times-circle fa-2x mr-3"></i>
                    <div>
                        <h3 class="mb-0">@Model.Count(c => !c.IsActive)</h3>
                        <small>Inactive Companies</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-info text-white">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <i class="fas fa-globe fa-2x mr-3"></i>
                    <div>
                        <h3 class="mb-0">@Model.Count(c => !string.IsNullOrEmpty(c.Website))</h3>
                        <small>With Websites</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Search and Filter -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-search"></i> Search & Filter</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <input type="text" id="searchInput" class="form-control" placeholder="Search companies...">
                    </div>
                    
                    <div class="col-md-3">
                        <button id="clearFilters" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Clear Filters
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Companies Table -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="fas fa-list"></i> All Companies</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover" id="companiesTable">
                        <thead class="thead-light">
                            <tr>
                                <th>Company</th>
                                <th>Description</th>
                                <th>Website</th>
                                <th>Date Added</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var company in Model.OrderBy(c => c.Name))
                            {
                                <tr data-company-id="@company.Id">
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="company-logo mr-3">
                                                @if (!string.IsNullOrEmpty(company.LogoUrl))
                                                {
                                                    <img src="@company.LogoUrl" alt="@company.Name" 
                                                         class="company-logo img-fluid rounded" 
                                                         style="max-height: 40px; width: auto;" />
                                                }
                                                else
                                                {
                                                    <div class="company-placeholder">
                                                        <i class="fas fa-building fa-2x text-muted"></i>
                                                    </div>
                                                }
                                            </div>
                                            <div>
                                                <strong>@company.Name</strong>
                                                <br>
                                                <small class="text-muted">ID: @company.Id</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="company-description" data-full="@company.Description">
                                            @if (company.Description?.Length > 50)
                                            {
                                                @Html.Raw(company.Description.Substring(0, 50) + "...")
                                                <button class="btn btn-link btn-sm p-0 toggle-description">
                                                    <small>Show More</small>
                                                </button>
                                            }
                                            else
                                            {
                                                @company.Description
                                            }
                                        </span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(company.Website))
                                        {
                                            <a href="@company.Website" target="_blank" class="text-primary">
                                                <i class="fas fa-external-link-alt"></i> Website
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <small>
                                            @company.CreatedDate.ToString("MMM dd, yyyy")
                                            <br>
                                            @company.CreatedDate.ToString("hh:mm tt")
                                        </small>
                                    </td>
                                    <td>
                                        @if (company.IsActive)
                                        {
                                            <span class="badge badge-success">
                                                <i class="fas fa-check"></i> Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger">
                                                <i class="fas fa-times"></i> Inactive
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            @if (company.IsActive)
                                            {
                                                <a href="@Url.Action("EditCompany", new { id = company.Id })" 
                                                   class="btn btn-sm btn-outline-primary" title="Edit">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <button class="btn btn-sm btn-outline-danger" 
                                                        onclick="deleteCompany(@company.Id, '@company.Name')" title="Delete">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="text-muted"><small>Deleted</small></span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                @if (!Model.Any())
                {
                    <div class="text-center py-4">
                        <i class="fas fa-building fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted">No companies found</h5>
                        <p class="text-muted">Start by adding your first company.</p>
                        <a href="@Url.Action("AddCompany")" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Add Company
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="fas fa-exclamation-triangle"></i> Confirm Delete
                </h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete the company <strong id="companyName"></strong>?</p>
                <div class="alert alert-warning">
                    <i class="fas fa-info-circle"></i>
                    <strong>Note:</strong> This will mark the company as inactive. All associated data will be preserved.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <form id="deleteForm" method="post" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteCompanyId" name="id" value="" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Delete Company
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .company-logo {
        border: 1px solid #dee2e6;
    }
    
    .table td {
        vertical-align: middle;
    }
    
    .company-placeholder {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 4px;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Search functionality
            $('#searchInput').on('keyup', function() {
                filterTable();
            });
            
            // Status filter
            $('#statusFilter').on('change', function() {
                filterTable();
            });
            
            // Clear filters
            $('#clearFilters').on('click', function() {
                $('#searchInput').val('');
                $('#statusFilter').val('');
                filterTable();
            });
            
            // Toggle description
            $('.toggle-description').on('click', function() {
                const $span = $(this).siblings('.company-description');
                const $button = $(this);
                const fullDescription = $span.data('full');
                const isExpanded = $button.data('expanded');
                
                if (isExpanded) {
                    const shortDescription = fullDescription.length > 50 ? fullDescription.substring(0, 50) + '...' : fullDescription;
                    $span.text(shortDescription);
                    $button.html('<small>Show More</small>');
                    $button.data('expanded', false);
                } else {
                    $span.text(fullDescription);
                    $button.html('<small>Show Less</small>');
                    $button.data('expanded', true);
                }
            });
        });
        
        function filterTable() {
            const searchTerm = $('#searchInput').val().toLowerCase();
            const statusFilter = $('#statusFilter').val();
            
            $('#companiesTable tbody tr').each(function() {
                const $row = $(this);
                const companyName = $row.find('strong').text().toLowerCase();
                const description = $row.find('.company-description').text().toLowerCase();
                const isActive = $row.find('.badge-success').length > 0;
                
                let showRow = true;
                
                // Search filter
                if (searchTerm && !companyName.includes(searchTerm) && !description.includes(searchTerm)) {
                    showRow = false;
                }
                
                // Status filter
                if (statusFilter === 'active' && !isActive) {
                    showRow = false;
                } else if (statusFilter === 'inactive' && isActive) {
                    showRow = false;
                }
                
                $row.toggle(showRow);
            });
            
            // Show "no results" message if needed
            const visibleRows = $('#companiesTable tbody tr:visible').length;
            if (visibleRows === 0) {
                if ($('#noResults').length === 0) {
                    $('#companiesTable tbody').append('<tr id="noResults"><td colspan="6" class="text-center py-4"><i class="fas fa-search fa-2x text-muted mb-2"></i><br><span class="text-muted">No companies match your search criteria</span></td></tr>');
                }
            } else {
                $('#noResults').remove();
            }
        }
        
        function deleteCompany(companyId, companyName) {
            $('#companyName').text(companyName);
            $('#deleteCompanyId').val(companyId);
            $('#deleteForm').attr('action', '@Url.Action("DeleteCompany", "Admin")');
            $('#deleteModal').modal('show');
        }
        
        // Handle form submission with loading state
        $('#deleteForm').on('submit', function() {
            // Close modal
            $('#deleteModal').modal('hide');
            
            // Show loading overlay
            $('body').append('<div id="loadingOverlay" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 9999; display: flex; align-items: center; justify-content: center;"><div class="spinner-border text-light" role="status"><span class="sr-only">Deleting...</span></div></div>');
        });
        
        // Auto-hide success and error messages
        setTimeout(function() {
            $('.alert-success, .alert-danger').fadeOut();
        }, 5000);
    </script>
}