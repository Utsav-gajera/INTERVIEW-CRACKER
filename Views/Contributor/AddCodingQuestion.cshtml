@model InterviewCracker.Models.CodingQuestion


@{
    ViewData["Title"] = "Add Coding Question";
}

@section Styles {
    <link href="~/css/mcq-form.css?v=@DateTime.UtcNow.Ticks" rel="stylesheet" />
    <style>
        /* CRITICAL SPACING FIXES - Highest Priority */
        .card-body .mb-3 { margin-bottom: 2.5rem !important; }
        .card-body .row { margin-bottom: 2rem !important; }
        .card-body { padding: 2.5rem !important; }
        
        /* Enhanced form styling */
        .form-label {
            font-weight: 600 !important;
            color: #495057 !important;
        }
        
        .form-control:focus, .form-select:focus {
            border-color: #4e73df !important;
            box-shadow: 0 0 0 0.2rem rgba(78, 115, 223, 0.25) !important;
        }
        
        /* Code input styling - Enhanced for proper formatting */
        .code-input {
            font-family: 'Courier New', 'Monaco', 'Menlo', 'Consolas', monospace !important;
            font-size: 0.875rem !important;
            background-color: #f8f9fa !important;
            white-space: pre-wrap !important; /* Preserves spaces and line breaks */
            tab-size: 4 !important; /* Sets tab width to 4 spaces */
            line-height: 1.4 !important; /* Better line spacing for code */
            overflow-wrap: break-word !important; /* Handles long lines */
            word-wrap: break-word !important;
        }
        
        /* Fix dropdown width issues */
        #CollegeId, #CompanyId, #Difficulty {
            width: 100% !important;
        }
        
        #CollegeId option, #CompanyId option, #Difficulty option {
            white-space: normal;
            word-wrap: break-word;
            padding: 8px 12px;
        }
        
        /* Ensure dropdowns show full content when opened */
        select.form-control {
            box-sizing: border-box;
        }
    </style>
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>
                <i class="fas fa-code text-success"></i>
                Add Coding Question
            </h2>
            <a href="@Url.Action("MyQuestions")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to My Questions
            </a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-10 mx-auto">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">
                    <i class="fas fa-laptop-code"></i>
                    Coding Question Details
                </h5>
            </div>
            <div class="card-body">
                @if (TempData["Message"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                    Layout = "~/Views/Shared/_Layout.cshtml";
                        <i class="fas fa-check-circle"></i>
                        @TempData["Message"]
                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-triangle"></i>
                        @TempData["Error"]
                        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                }

                <form asp-action="AddCodingQuestion" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <!-- Title -->
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">
                            <i class="fas fa-heading"></i> Question Title *
                        </label>
                        <input asp-for="Title" class="form-control" placeholder="e.g., Two Sum, Reverse Linked List, Binary Search">
                        <span asp-validation-for="Title" class="text-danger"></span>
                        <small class="form-text text-muted">A clear, descriptive title for your coding problem</small>
                    </div>

                    <!-- Problem Statement -->
                    <div class="mb-3">
                        <label asp-for="Problem" class="form-label">
                            <i class="fas fa-file-alt"></i> Problem Statement *
                        </label>
                        <textarea asp-for="Problem" class="form-control" rows="8" 
                                  placeholder="Describe the problem clearly. Include:&#10;- Problem description&#10;- Input/Output format&#10;- Constraints&#10;- Examples"></textarea>
                        <span asp-validation-for="Problem" class="text-danger"></span>
                        <small class="form-text text-muted">Provide a detailed problem description with examples</small>
                    </div>

                    <!-- Description Field -->
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">
                            <i class="fas fa-info-circle"></i> Description *
                        </label>
                        <textarea asp-for="Description" class="form-control" rows="4" 
                                  placeholder="Brief description or summary of the problem"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                        <small class="form-text text-muted">Provide a concise description of the coding question</small>
                    </div>

                    <!-- Sample Input and Output -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="SampleInput" class="form-label">
                                    <i class="fas fa-arrow-right text-primary"></i> Sample Input
                                </label>
                                <textarea asp-for="SampleInput" class="form-control code-input" rows="4" 
                                          placeholder="Example:&#10;5&#10;[1, 2, 3, 4, 5]"></textarea>
                                <small class="form-text text-muted">Provide sample input data (formatting preserved)</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="SampleOutput" class="form-label">
                                    <i class="fas fa-arrow-left text-success"></i> Sample Output
                                </label>
                                <textarea asp-for="SampleOutput" class="form-control code-input" rows="4" 
                                          placeholder="Example:&#10;15"></textarea>
                                <small class="form-text text-muted">Expected output for the sample input (formatting preserved)</small>
                            </div>
                        </div>
                    </div>

                    <!-- Solution -->
                    <div class="mb-3">
                        <label asp-for="Solution" class="form-label">
                            <i class="fas fa-code text-info"></i> Solution Code
                        </label>
                        <textarea asp-for="Solution" class="form-control code-input" rows="12" 
                                  placeholder="Provide your solution code here (optional but recommended)...&#10;&#10;Example:&#10;public int[] TwoSum(int[] nums, int target) {&#10;    // Your solution code&#10;}"></textarea>
                        <small class="form-text text-muted">
                            <i class="fas fa-info-circle"></i> Optional: Provide a working solution for reference. 
                            <strong>Your code formatting, spaces, and indentation will be preserved.</strong>
                        </small>
                    </div>

                    <!-- Company and College -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="CollegeId" class="form-label">
                                    <i class="fas fa-university"></i> College
                                </label>
                                <select asp-for="CollegeId" id="CollegeId" class="form-select">
                                    <option value="0">Select College</option>
                                    @if (ViewBag.Colleges != null)
                                    {
                                        @foreach (var college in (List<InterviewCracker.Models.College>)ViewBag.Colleges)
                                        {
                                            <option value="@college.Id">@college.Name</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="CollegeId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="CompanyId" class="form-label">
                                    <i class="fas fa-building"></i> Company
                                </label>
                                <select asp-for="CompanyId" id="CompanyId" class="form-select">
                                    <option value="0">Select College First</option>
                                </select>
                                <span asp-validation-for="CompanyId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Year and Difficulty -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Year" class="form-label">
                                    <i class="fas fa-calendar"></i> Year
                                </label>
                                <input asp-for="Year" type="number" class="form-control" 
                                       min="2000" max="@DateTime.Now.Year" 
                                       value="@DateTime.Now.Year" placeholder="2025">
                                <span asp-validation-for="Year" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Difficulty" class="form-label">
                                    <i class="fas fa-chart-bar"></i> Difficulty Level
                                </label>
                                <select asp-for="Difficulty" id="Difficulty" class="form-select">
                                    <option value="">Select Difficulty</option>
                                    <option value="Easy">Easy</option>
                                    <option value="Medium">Medium</option>
                                    <option value="Hard">Hard</option>
                                </select>
                                <span asp-validation-for="Difficulty" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Guidelines -->
                    <div class="alert alert-info">
                        <h6><i class="fas fa-info-circle"></i> Guidelines for Coding Questions:</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <ul class="mb-0">
                                    <li>Use clear and concise problem descriptions</li>
                                    <li>Include multiple test cases in examples</li>
                                    <li>Specify input/output formats clearly</li>
                                    <li>Mention time and space complexity constraints</li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <ul class="mb-0">
                                    <li>Provide edge cases in your examples</li>
                                    <li>Include a working solution for verification</li>
                                    <li>Use proper formatting for code snippets</li>
                                    <li>Questions will be reviewed before publication</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Preview Section -->
                    <div class="card bg-light mb-3">
                        <div class="card-header">
                            <h6 class="mb-0"><i class="fas fa-eye"></i> Preview</h6>
                        </div>
                        <div class="card-body" id="preview-content">
                            <p class="text-muted">Fill in the form above to see a preview of your question</p>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="mb-3 text-center">
                        <button type="submit" id="submitBtn" class="btn btn-success btn-lg me-3">
                            <span id="btn-text">
                                <i class="fas fa-save"></i> Save Coding Question
                            </span>
                            <span id="btn-loading" style="display: none;">
                                <i class="fas fa-spinner fa-spin"></i> Saving Question...
                            </span>
                        </button>
                        <a href="@Url.Action("MyQuestions")" class="btn btn-secondary btn-lg">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        $(document).ready(function() {
            // Function to load companies based on selected college
            function loadCompaniesByCollege() {
                var selectedCollegeId = $('#CollegeId').val();
                var companySelect = $('#CompanyId');
                
                // Clear current options except the first one
                companySelect.empty();
                companySelect.append('<option value="">Select Company</option>');
                
                if (selectedCollegeId) {
                    // Make AJAX call to get companies for the selected college
                    $.ajax({
                        url: '@Url.Action("GetCompaniesByCollege", "Contributor")',
                        type: 'GET',
                        data: { collegeId: selectedCollegeId },
                        success: function(companies) {
                            if (companies && companies.length > 0) {
                                $.each(companies, function(index, company) {
                                    companySelect.append($('<option></option>')
                                        .attr('value', company.id)
                                        .text(company.name));
                                });
                            } else {
                                companySelect.append('<option value="" disabled>No companies available for this college</option>');
                            }
                        },
                        error: function(xhr, status, error) {
                            console.error('Error loading companies:', error);
                            companySelect.append('<option value="" disabled>Error loading companies</option>');
                        }
                    });
                }
                
                // Reset company selection
                companySelect.val('');
            }
            
            // Bind college change event
            $('#CollegeId').change(function() {
                loadCompaniesByCollege();
            });
            
            // Real-time preview
            function updatePreview() {
                const title = $('#Title').val().trim();
                const problem = $('#Problem').val().trim();
                const sampleInput = $('#SampleInput').val().trim();
                const sampleOutput = $('#SampleOutput').val().trim();
                const difficulty = $('#Difficulty').val();
                
                let previewHtml = '';
                
                if (title) {
                    previewHtml += `<div class="preview-title">${title}</div>`;
                }
                
                if (difficulty) {
                    const badgeClass = difficulty === 'Easy' ? 'badge-success' : 
                                     difficulty === 'Medium' ? 'badge-warning' : 'badge-danger';
                    previewHtml += `<span class="badge ${badgeClass} mb-2">${difficulty}</span><br>`;
                }
                
                if (problem) {
                    previewHtml += `<div class="preview-problem">${problem}</div>`;
                }
                
                if (sampleInput || sampleOutput) {
                    previewHtml += '<div class="row">';
                    if (sampleInput) {
                        previewHtml += `
                            <div class="col-md-6">
                                <strong>Sample Input:</strong>
                                <div class="preview-io">${sampleInput}</div>
                            </div>`;
                    }
                    if (sampleOutput) {
                        previewHtml += `
                            <div class="col-md-6">
                                <strong>Sample Output:</strong>
                                <div class="preview-io">${sampleOutput}</div>
                            </div>`;
                    }
                    previewHtml += '</div>';
                }
                
                if (!previewHtml) {
                    previewHtml = '<p class="text-muted">Fill in the form above to see a preview of your question</p>';
                }
                
                $('#preview-content').html(previewHtml);
            }
            
            // Update preview on input
            $('#Title, #Problem, #SampleInput, #SampleOutput, #Difficulty').on('input change', updatePreview);
            
            // Character counters
            function addCharacterCounter(selector, maxLength) {
                $(selector).on('input', function() {
                    const currentLength = $(this).val().length;
                    const remaining = maxLength - currentLength;
                    
                    let counter = $(this).siblings('.char-counter');
                    if (counter.length === 0) {
                        counter = $('<small class="char-counter text-muted"></small>');
                        $(this).after(counter);
                    }
                    
                    counter.text(`${currentLength}/${maxLength} characters`);
                    
                    if (remaining < 100) {
                        counter.removeClass('text-muted').addClass('text-warning');
                    }
                    if (remaining < 0) {
                        counter.removeClass('text-warning').addClass('text-danger');
                    }
                });
            }
            
            addCharacterCounter('#Title', 200);
            addCharacterCounter('#Problem', 5000);
            addCharacterCounter('#Description', 1000);
            
            // Form validation with loading state management
            var isSubmitting = false;
            
            $('form').on('submit', function(e) {
                // Prevent double submission
                if (isSubmitting) {
                    e.preventDefault();
                    return false;
                }
                
                const title = $('#Title').val().trim();
                const problem = $('#Problem').val().trim();
                const description = $('#Description').val().trim();
                const collegeId = $('#CollegeId').val();
                const companyId = $('#CompanyId').val();
                const difficulty = $('#Difficulty').val();
                
                // Reset button state first
                resetSubmitButton();
                
                // Client-side validation
                if (!title || !problem || !description) {
                    e.preventDefault();
                    alert('Please fill in the required fields: Title, Problem Statement, and Description.');
                    return false;
                }
                
                if (title.length < 5) {
                    e.preventDefault();
                    alert('Title must be at least 5 characters long.');
                    $('#Title').focus();
                    return false;
                }
                
                if (problem.length < 50) {
                    e.preventDefault();
                    alert('Problem statement must be at least 50 characters long.');
                    $('#Problem').focus();
                    return false;
                }
                
                if (description.length < 10) {
                    e.preventDefault();
                    alert('Description must be at least 10 characters long.');
                    $('#Description').focus();
                    return false;
                }
                
                if (!collegeId || collegeId === '0') {
                    e.preventDefault();
                    alert('Please select a college.');
                    $('#CollegeId').focus();
                    return false;
                }
                
                if (!companyId || companyId === '0') {
                    e.preventDefault();
                    alert('Please select a company.');
                    $('#CompanyId').focus();
                    return false;
                }
                
                if (!difficulty) {
                    e.preventDefault();
                    alert('Please select a difficulty level.');
                    $('#Difficulty').focus();
                    return false;
                }
                
                // If validation passes, show loading state
                showLoadingState();
                isSubmitting = true;
                
                // Let the form submit normally
                return true;
            });
            
            function showLoadingState() {
                $('#submitBtn').prop('disabled', true);
                $('#btn-text').hide();
                $('#btn-loading').show();
            }
            
            function resetSubmitButton() {
                $('#submitBtn').prop('disabled', false);
                $('#btn-text').show();
                $('#btn-loading').hide();
                isSubmitting = false;
            }
            
            // Reset button state if there are server-side validation errors on page load
            if ($('.text-danger').text().trim() !== '' || $('.alert-danger').length > 0) {
                resetSubmitButton();
            }
            
            // Initialize preview
            updatePreview();
        });
    </script>
}