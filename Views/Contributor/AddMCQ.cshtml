@model InterviewCracker.Models.MCQ

@{
    ViewData["Title"] = "Add MCQ";
}

@section Styles {
    <link href="~/css/mcq-form.css?v=@DateTime.UtcNow.Ticks" rel="stylesheet" />
    <style>
        /* CRITICAL SPACING FIXES - Highest Priority */
        .card-body .mb-3 { margin-bottom: 2.5rem !important; }
        .card-body .row { margin-bottom: 2rem !important; }
        .card-body .alert { margin: 2.5rem 0 !important; }
        .card-body .text-center { margin-top: 3rem !important; }
        .card-body { padding: 2.5rem !important; }
        
        /* Specific section spacing improvements */
        .mb-3:has(select[asp-for="CorrectAnswer"]) { margin-bottom: 3rem !important; }
        .mb-3:has(textarea[asp-for="Explanation"]) { margin-bottom: 3rem !important; }
        .row:has(select[asp-for="CollegeId"]) { margin-bottom: 2.5rem !important; }
        .row:has(input[asp-for="Year"]) { margin-bottom: 3rem !important; }
        
        /* Extra spacing for visual sections */
        .form-label {
            font-weight: 600 !important;
            margin-bottom: 0.75rem !important;
            color: #495057 !important;
        }
        
        /* Enhanced form controls */
        .form-control, .form-select {
            padding: 0.875rem 1rem !important;
            border-radius: 8px !important;
            border: 1px solid #ced4da !important;
            margin-bottom: 0.5rem !important;
            background-color: #fff !important;
            font-size: 1rem !important;
            line-height: 1.5 !important;
            transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out !important;
        }
        
        /* Fix select box focus and active states */
        .form-select:focus,
        .form-control:focus {
            border-color: #4e73df !important;
            box-shadow: 0 0 0 0.2rem rgba(78, 115, 223, 0.25) !important;
            outline: none !important;
        }
        
        /* Fix select dropdown arrow */
        .form-select {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23343a40' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m1 6 7 7 7-7'/%3e%3c/svg%3e") !important;
            background-repeat: no-repeat !important;
            background-position: right 0.75rem center !important;
            background-size: 16px 12px !important;
            padding-right: 2.5rem !important;
        }
        
        /* Remove any unwanted highlights or outlines */
        .form-select:not([multiple]):not([size]),
        .form-control {
            appearance: none !important;
            -webkit-appearance: none !important;
            -moz-appearance: none !important;
        }
        
        /* Better button spacing */
        .btn-lg {
            padding: 0.875rem 2.5rem !important;
            margin: 0 0.5rem !important;
        }
        
        /* Additional select box consistency fixes */
        select.form-select option {
            padding: 0.5rem !important;
            background-color: #fff !important;
            color: #495057 !important;
        }
        
        /* Remove browser-specific select styling */
        .form-select::-ms-expand {
            display: none !important;
        }
        
        /* Ensure consistent height for all form controls */
        .form-control,
        .form-select {
            height: auto !important;
            min-height: calc(1.5em + 1.75rem + 2px) !important;
        }
        
        /* Fix dropdown width issues */
        #CollegeId, #CompanyId, #Difficulty, #CorrectAnswer {
            width: 100% !important;
            min-width: 250px;
            white-space: normal !important;
            overflow: visible !important;
            text-overflow: unset !important;
            height: auto !important;
            padding: 8px 12px;
            /* Remove duplicate dropdown arrows */
            -webkit-appearance: none;
            -moz-appearance: none;
            appearance: none;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23343a40' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 0.75rem center;
            background-size: 16px 12px;
            padding-right: 2.25rem;
        }
        
        #CollegeId option, #CompanyId option, #Difficulty option, #CorrectAnswer option {
            white-space: normal;
            word-wrap: break-word;
            padding: 8px 12px;
        }
        
        /* Ensure dropdowns show full content when opened */
        select.form-control {
            box-sizing: border-box;
        }
    </style>
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>
                <i class="fas fa-plus-circle text-primary"></i>
                Add MCQ Question
            </h2>
            <a href="@Url.Action("MyQuestions")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to My Questions
            </a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="fas fa-question-circle"></i>
                    MCQ Details
                </h5>
            </div>
            <div class="card-body">
                <form asp-action="AddMCQ" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <!-- Question -->
                    <div class="mb-3">
                        <label asp-for="Question" class="form-label">
                            <i class="fas fa-question"></i> Question *
                        </label>
                        <textarea asp-for="Question" class="form-control" rows="4" 
                                  placeholder="Enter your multiple choice question here..."></textarea>
                        <span asp-validation-for="Question" class="text-danger"></span>
                    </div>

                    <!-- Options -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="OptionA" class="form-label">
                                    <i class="fas fa-circle text-primary"></i> Option A *
                                </label>
                                <input asp-for="OptionA" class="form-control" placeholder="Option A">
                                <span asp-validation-for="OptionA" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="OptionB" class="form-label">
                                    <i class="fas fa-circle text-success"></i> Option B *
                                </label>
                                <input asp-for="OptionB" class="form-control" placeholder="Option B">
                                <span asp-validation-for="OptionB" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="OptionC" class="form-label">
                                    <i class="fas fa-circle text-warning"></i> Option C *
                                </label>
                                <input asp-for="OptionC" class="form-control" placeholder="Option C">
                                <span asp-validation-for="OptionC" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="OptionD" class="form-label">
                                    <i class="fas fa-circle text-danger"></i> Option D *
                                </label>
                                <input asp-for="OptionD" class="form-control" placeholder="Option D">
                                <span asp-validation-for="OptionD" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Correct Answer -->
                    <div class="mb-3">
                        <label asp-for="CorrectAnswer" class="form-label">
                            <i class="fas fa-check-circle text-success"></i> Correct Answer *
                        </label>
                        <select asp-for="CorrectAnswer" id="CorrectAnswer" class="form-select">
                            <option value="">Select the correct answer</option>
                            <option value="A">A</option>
                            <option value="B">B</option>
                            <option value="C">C</option>
                            <option value="D">D</option>
                        </select>
                        <span asp-validation-for="CorrectAnswer" class="text-danger"></span>
                    </div>

                    <!-- Explanation -->
                    <div class="mb-3">
                        <label asp-for="Explanation" class="form-label">
                            <i class="fas fa-lightbulb text-warning"></i> Explanation
                        </label>
                        <textarea asp-for="Explanation" class="form-control" rows="3" 
                                  placeholder="Provide a clear explanation for the correct answer..."></textarea>
                        <small class="form-text text-muted">Optional but recommended to help students understand</small>
                    </div>

                    <!-- Company and College -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="CollegeId" class="form-label">
                                    <i class="fas fa-university"></i> College
                                </label>
                                <select asp-for="CollegeId" id="CollegeId" class="form-select">
                                    <option value="">Select College</option>
                                    @if (ViewBag.Colleges != null)
                                    {
                                        @foreach (var college in (List<InterviewCracker.Models.College>)ViewBag.Colleges)
                                        {
                                            <option value="@college.Id">@college.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="CompanyId" class="form-label">
                                    <i class="fas fa-building"></i> Company
                                </label>
                                <select asp-for="CompanyId" id="CompanyId" class="form-select">
                                    <option value="">Select Company</option>
                                    @if (ViewBag.Companies != null)
                                    {
                                        @foreach (var company in (List<InterviewCracker.Models.Company>)ViewBag.Companies)
                                        {
                                            <option value="@company.Id">@company.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Year and Difficulty -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Year" class="form-label">
                                    <i class="fas fa-calendar"></i> Year
                                </label>
                                <input asp-for="Year" type="number" class="form-control" 
                                       min="2000" max="@DateTime.Now.Year" 
                                       value="@DateTime.Now.Year" placeholder="2025">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Difficulty" class="form-label">
                                    <i class="fas fa-chart-bar"></i> Difficulty Level
                                </label>
                                <select asp-for="Difficulty" class="form-select">
                                    <option value="">Select Difficulty</option>
                                    <option value="Easy">Easy</option>
                                    <option value="Medium">Medium</option>
                                    <option value="Hard">Hard</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Guidelines -->
                    <div class="alert alert-info">
                        <h6><i class="fas fa-info-circle"></i> Guidelines:</h6>
                        <ul class="mb-0">
                            <li>Ensure your question is clear and unambiguous</li>
                            <li>All options should be plausible to avoid obvious answers</li>
                            <li>Provide detailed explanations to help students learn</li>
                            <li>Questions will be reviewed by admins before publication</li>
                        </ul>
                    </div>

                    <!-- Buttons -->
                    <div class="mb-3 text-center">
                        <button type="submit" class="btn btn-primary btn-lg me-3">
                            <i class="fas fa-save"></i> Save MCQ
                        </button>
                        <a href="@Url.Action("MyQuestions")" class="btn btn-secondary btn-lg">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        $(document).ready(function() {
            // Function to load companies based on selected college
            function loadCompaniesByCollege() {
                var selectedCollegeId = $('#CollegeId').val();
                var companySelect = $('#CompanyId');
                
                // Clear current options except the first one
                companySelect.empty();
                companySelect.append('<option value="">Select Company</option>');
                
                if (selectedCollegeId) {
                    // Make AJAX call to get companies for the selected college
                    $.ajax({
                        url: '@Url.Action("GetCompaniesByCollege", "Contributor")',
                        type: 'GET',
                        data: { collegeId: selectedCollegeId },
                        success: function(companies) {
                            if (companies && companies.length > 0) {
                                $.each(companies, function(index, company) {
                                    companySelect.append($('<option></option>')
                                        .attr('value', company.id)
                                        .text(company.name));
                                });
                            } else {
                                companySelect.append('<option value="" disabled>No companies available for this college</option>');
                            }
                        },
                        error: function(xhr, status, error) {
                            console.error('Error loading companies:', error);
                            companySelect.append('<option value="" disabled>Error loading companies</option>');
                        }
                    });
                }
                
                // Reset company selection
                companySelect.val('');
            }
            
            // Bind college change event
            $('#CollegeId').change(function() {
                loadCompaniesByCollege();
            });
            
            // Character counter for question
            $('#Question').on('input', function() {
                const maxLength = 1000;
                const currentLength = $(this).val().length;
                const remaining = maxLength - currentLength;
                
                let counter = $(this).siblings('.char-counter');
                if (counter.length === 0) {
                    counter = $('<small class="char-counter text-muted"></small>');
                    $(this).after(counter);
                }
                
                counter.text(`${currentLength}/${maxLength} characters`);
                
                if (remaining < 50) {
                    counter.removeClass('text-muted').addClass('text-warning');
                }
                if (remaining < 0) {
                    counter.removeClass('text-warning').addClass('text-danger');
                }
            });
            
            // Form validation enhancement
            $('form').on('submit', function(e) {
                const question = $('#Question').val().trim();
                const optionA = $('#OptionA').val().trim();
                const optionB = $('#OptionB').val().trim();
                const optionC = $('#OptionC').val().trim();
                const optionD = $('#OptionD').val().trim();
                const correctAnswer = $('#CorrectAnswer').val();
                
                if (!question || !optionA || !optionB || !optionC || !optionD || !correctAnswer) {
                    e.preventDefault();
                    alert('Please fill in all required fields (Question, all Options, and Correct Answer).');
                    return false;
                }
                
                if (question.length < 10) {
                    e.preventDefault();
                    alert('Question must be at least 10 characters long.');
                    $('#Question').focus();
                    return false;
                }
            });
        });
    </script>
}