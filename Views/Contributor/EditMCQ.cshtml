@model InterviewCracker.Models.MCQ

@{
    ViewData["Title"] = "Edit MCQ";
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>
                <i class="fas fa-edit text-warning"></i>
                Edit MCQ Question
            </h2>
            <a href="@Url.Action("MyQuestions")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to My Questions
            </a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card shadow">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">
                    <i class="fas fa-question-circle"></i>
                    Edit MCQ Details
                </h5>
            </div>
            <div class="card-body">
                <form asp-action="EditMCQ" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <!-- Status Alert -->
                    @if (Model?.IsApproved == true)
                    {
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i>
                            <strong>Note:</strong> This MCQ is currently approved. Editing will reset its approval status.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-clock"></i>
                            <strong>Status:</strong> This MCQ is pending approval.
                        </div>
                    }
                    
                    <!-- Question -->
                    <div class="form-group">
                        <label asp-for="Question" class="form-label font-weight-bold">
                            <i class="fas fa-question"></i> Question *
                        </label>
                        <textarea asp-for="Question" class="form-control" rows="4" 
                                  placeholder="Enter your multiple choice question here..."></textarea>
                        <span asp-validation-for="Question" class="text-danger"></span>
                    </div>

                    <!-- Options -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="OptionA" class="form-label font-weight-bold">
                                    <i class="fas fa-circle text-primary"></i> Option A *
                                </label>
                                <input asp-for="OptionA" class="form-control" placeholder="Option A">
                                <span asp-validation-for="OptionA" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="OptionB" class="form-label font-weight-bold">
                                    <i class="fas fa-circle text-success"></i> Option B *
                                </label>
                                <input asp-for="OptionB" class="form-control" placeholder="Option B">
                                <span asp-validation-for="OptionB" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="OptionC" class="form-label font-weight-bold">
                                    <i class="fas fa-circle text-warning"></i> Option C *
                                </label>
                                <input asp-for="OptionC" class="form-control" placeholder="Option C">
                                <span asp-validation-for="OptionC" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="OptionD" class="form-label font-weight-bold">
                                    <i class="fas fa-circle text-danger"></i> Option D *
                                </label>
                                <input asp-for="OptionD" class="form-control" placeholder="Option D">
                                <span asp-validation-for="OptionD" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Correct Answer -->
                    <div class="form-group">
                        <label asp-for="CorrectAnswer" class="form-label font-weight-bold">
                            <i class="fas fa-check-circle text-success"></i> Correct Answer *
                        </label>
                        <select asp-for="CorrectAnswer" id="CorrectAnswer" class="form-control">
                            <option value="">Select the correct answer</option>
                            <option value="A">A</option>
                            <option value="B">B</option>
                            <option value="C">C</option>
                            <option value="D">D</option>
                        </select>
                        <span asp-validation-for="CorrectAnswer" class="text-danger"></span>
                    </div>

                    <!-- Explanation -->
                    <div class="form-group">
                        <label asp-for="Explanation" class="form-label font-weight-bold">
                            <i class="fas fa-lightbulb text-warning"></i> Explanation
                        </label>
                        <textarea asp-for="Explanation" class="form-control" rows="3" 
                                  placeholder="Provide a clear explanation for the correct answer..."></textarea>
                        <small class="form-text text-muted">Optional but recommended to help students understand</small>
                    </div>

                    <!-- Company and College -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="CollegeId" class="form-label font-weight-bold">
                                    <i class="fas fa-university"></i> College
                                </label>
                                <select asp-for="CollegeId" id="CollegeId" class="form-control">
                                    <option value="">Select College</option>
                                    @if (ViewBag.Colleges != null)
                                    {
                                        @foreach (var college in (List<InterviewCracker.Models.College>)ViewBag.Colleges)
                                        {
                                            <option value="@college.Id">@college.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="CompanyId" class="form-label font-weight-bold">
                                    <i class="fas fa-building"></i> Company
                                </label>
                                <select asp-for="CompanyId" id="CompanyId" class="form-control">
                                    <option value="">Select Company</option>
                                    @if (ViewBag.Companies != null)
                                    {
                                        @foreach (var company in (List<InterviewCracker.Models.Company>)ViewBag.Companies)
                                        {
                                            <option value="@company.Id">@company.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Year and Difficulty -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Year" class="form-label font-weight-bold">
                                    <i class="fas fa-calendar"></i> Year
                                </label>
                                <input asp-for="Year" type="number" class="form-control" 
                                       min="2000" max="@DateTime.Now.Year" placeholder="2024">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Difficulty" class="form-label font-weight-bold">
                                    <i class="fas fa-chart-bar"></i> Difficulty Level
                                </label>
                                <select asp-for="Difficulty" class="form-control">
                                    <option value="">Select Difficulty</option>
                                    <option value="Easy">Easy</option>
                                    <option value="Medium">Medium</option>
                                    <option value="Hard">Hard</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Guidelines -->
                    <div class="alert alert-info">
                        <h6><i class="fas fa-info-circle"></i> Guidelines:</h6>
                        <ul class="mb-0">
                            <li>Ensure your question is clear and unambiguous</li>
                            <li>All options should be plausible to avoid obvious answers</li>
                            <li>Provide detailed explanations to help students learn</li>
                            <li><strong>Note:</strong> Editing will reset the approval status</li>
                        </ul>
                    </div>

                    <!-- Preview Section -->
                    <div class="card bg-light mb-3">
                        <div class="card-header">
                            <h6 class="mb-0"><i class="fas fa-eye"></i> Preview</h6>
                        </div>
                        <div class="card-body" id="preview-content">
                            <!-- Preview will be populated by JavaScript -->
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="form-group text-center">
                        <button type="submit" class="btn btn-warning btn-lg mr-3">
                            <i class="fas fa-save"></i> Update MCQ
                        </button>
                        <a href="@Url.Action("MyQuestions")" class="btn btn-secondary btn-lg">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    textarea.form-control {
        resize: vertical;
        min-height: 100px;
    }
    
    .preview-question {
        background-color: #f8f9fa;
        padding: 15px;
        border-radius: 5px;
        margin-bottom: 15px;
        border-left: 4px solid #007bff;
    }
    
    .preview-options {
        margin-left: 20px;
    }
    
    .preview-option {
        margin-bottom: 8px;
        padding: 5px 10px;
        border-radius: 3px;
    }
    
    .preview-option.correct {
        background-color: #d4edda;
        border-left: 3px solid #28a745;
    }
    
    .preview-explanation {
        background-color: #fff3cd;
        padding: 10px;
        border-radius: 5px;
        border-left: 4px solid #ffc107;
        margin-top: 10px;
    }
    
    /* Fix dropdown width issues */
    #CollegeId, #CompanyId, #Difficulty, #CorrectAnswer {
        width: 100% !important;
        min-width: 250px;
        white-space: normal !important;
        overflow: visible !important;
        text-overflow: unset !important;
        height: auto !important;
        padding: 8px 12px;
        /* Remove duplicate dropdown arrows */
        -webkit-appearance: none;
        -moz-appearance: none;
        appearance: none;
        background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23343a40' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 0.75rem center;
        background-size: 16px 12px;
        padding-right: 2.25rem;
    }
    
    #CollegeId option, #CompanyId option, #Difficulty option, #CorrectAnswer option {
        white-space: normal;
        word-wrap: break-word;
        padding: 8px 12px;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        $(document).ready(function() {
            var selectedCollegeId = $('#CollegeId').val();
            var selectedCompanyId = $('#CompanyId').val();
            
            // Function to load companies based on selected college
            function loadCompaniesByCollege() {
                var newCollegeId = $('#CollegeId').val();
                var companySelect = $('#CompanyId');
                
                // Clear current options except the first one
                companySelect.empty();
                companySelect.append('<option value="">Select Company</option>');
                
                if (newCollegeId) {
                    // Make AJAX call to get companies for the selected college
                    $.ajax({
                        url: '@Url.Action("GetCompaniesByCollege", "Contributor")',
                        type: 'GET',
                        data: { collegeId: newCollegeId },
                        success: function(companies) {
                            if (companies && companies.length > 0) {
                                $.each(companies, function(index, company) {
                                    companySelect.append($('<option></option>')
                                        .attr('value', company.id)
                                        .text(company.name));
                                });
                                
                                // Restore previously selected company if it's still available
                                if (selectedCompanyId && newCollegeId === selectedCollegeId) {
                                    companySelect.val(selectedCompanyId);
                                }
                            } else {
                                companySelect.append('<option value="" disabled>No companies available for this college</option>');
                            }
                        },
                        error: function(xhr, status, error) {
                            console.error('Error loading companies:', error);
                            companySelect.append('<option value="" disabled>Error loading companies</option>');
                        }
                    });
                }
            }
            
            // Bind college change event
            $('#CollegeId').change(function() {
                loadCompaniesByCollege();
            });
            
            // Initial load - load companies for current college selection
            if (selectedCollegeId) {
                loadCompaniesByCollege();
            }
            
            // Real-time preview
            function updatePreview() {
                const question = $('#Question').val().trim();
                const optionA = $('#OptionA').val().trim();
                const optionB = $('#OptionB').val().trim();
                const optionC = $('#OptionC').val().trim();
                const optionD = $('#OptionD').val().trim();
                const correctAnswer = $('#CorrectAnswer').val();
                const explanation = $('#Explanation').val().trim();
                const difficulty = $('#Difficulty').val();
                
                let previewHtml = '';
                
                if (question) {
                    previewHtml += `<div class="preview-question">
                        <strong>Question:</strong> ${question}
                    </div>`;
                    
                    if (optionA || optionB || optionC || optionD) {
                        previewHtml += '<div class="preview-options">';
                        if (optionA) {
                            previewHtml += `<div class="preview-option ${correctAnswer === 'A' ? 'correct' : ''}">
                                A) ${optionA} ${correctAnswer === 'A' ? '✓' : ''}
                            </div>`;
                        }
                        if (optionB) {
                            previewHtml += `<div class="preview-option ${correctAnswer === 'B' ? 'correct' : ''}">
                                B) ${optionB} ${correctAnswer === 'B' ? '✓' : ''}
                            </div>`;
                        }
                        if (optionC) {
                            previewHtml += `<div class="preview-option ${correctAnswer === 'C' ? 'correct' : ''}">
                                C) ${optionC} ${correctAnswer === 'C' ? '✓' : ''}
                            </div>`;
                        }
                        if (optionD) {
                            previewHtml += `<div class="preview-option ${correctAnswer === 'D' ? 'correct' : ''}">
                                D) ${optionD} ${correctAnswer === 'D' ? '✓' : ''}
                            </div>`;
                        }
                        previewHtml += '</div>';
                    }
                    
                    if (explanation) {
                        previewHtml += `<div class="preview-explanation">
                            <strong>Explanation:</strong> ${explanation}
                        </div>`;
                    }
                    
                    if (difficulty) {
                        const badgeClass = difficulty === 'Easy' ? 'badge-success' : 
                                         difficulty === 'Medium' ? 'badge-warning' : 'badge-danger';
                        previewHtml += `<div class="mt-2">
                            <span class="badge ${badgeClass}">${difficulty}</span>
                        </div>`;
                    }
                }
                
                if (!previewHtml) {
                    previewHtml = '<p class="text-muted">Fill in the form above to see a preview of your question</p>';
                }
                
                $('#preview-content').html(previewHtml);
            }
            
            // Update preview on input
            $('#Question, #OptionA, #OptionB, #OptionC, #OptionD, #CorrectAnswer, #Explanation, #Difficulty').on('input change', updatePreview);
            
            // Initialize preview
            updatePreview();
        });
    </script>
}