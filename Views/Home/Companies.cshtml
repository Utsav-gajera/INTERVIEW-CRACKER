@model CompanyViewModel
@{
    ViewData["Title"] = $"Companies - {Model.College.Name}";
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="@Url.Action("Index", "Home")">
                <i class="fas fa-home"></i> Home
            </a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">
            @Model.College.Name
        </li>
    </ol>
</nav>

<!-- College Header -->
<div class="row mb-4">
    <div class="col-12">
        <div class="questions-header">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-2">
                        @if (!string.IsNullOrEmpty(Model.College.ImageUrl))
                        {
                            <img src="@Model.College.ImageUrl" alt="@Model.College.Name" 
                                 class="college-logo img-fluid rounded" style="max-height: 80px; width: auto;" />
                        }
                        else
                        {
                            <div class="college-placeholder">
                                <i class="fas fa-university fa-3x text-muted"></i>
                            </div>
                        }
                    </div>
                    <div class="col-md-6">
                        <h2 class="mb-2">
                            <i class="fas fa-university"></i> @Model.College.Name
                        </h2>
                        <p class="mb-2">@Model.College.Description</p>
                        <small>
                            <i class="fas fa-map-marker-alt"></i> @Model.College.Location
                        </small>
                    </div>
                    <div class="col-md-4 text-md-end">
                        <div class="college-stats">
                            <h4>@Model.Companies.Count</h4>
                            <p class="mb-0">Companies Visited</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Search Section -->
<div class="row mb-4">
    <div class="col-12">
        <div class="search-form-container">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-search"></i> Search Companies</h5>
            </div>
            <div class="search-form-body">
                <form method="get" asp-action="Companies">
                    <input type="hidden" name="collegeId" value="@Model.College.Id" />
                    <div class="row">
                        <div class="col-lg-10 col-md-8 mb-3">
                            <label for="searchTerm" class="form-label">Search Companies:</label>
                            <input type="text" class="form-control" id="searchTerm" name="searchTerm" 
                                   value="@Model.SearchTerm" placeholder="Enter company name or description...">
                        </div>
                        <div class="col-lg-2 col-md-4 mb-3 d-flex align-items-end">
                            <div class="search-buttons-container w-100">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-search"></i>&nbsp;Search
                                </button>
                                <a href="@Url.Action("Companies", new { collegeId = Model.College.Id })" class="btn btn-outline-secondary">
                                    <i class="fas fa-times"></i>&nbsp;Clear
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Search Results Info -->
@if (!string.IsNullOrEmpty(Model.SearchTerm))
{
    <div class="row mb-3">
        <div class="col-12">
            <div class="search-results-info">
                <i class="fas fa-info-circle"></i>
                <strong>Search Results:</strong> 
                Showing <span class="badge bg-primary text-white">@Model.Companies.Count</span> company(ies)
                matching "<strong>@Model.SearchTerm</strong>"
                <a href="@Url.Action("Companies", new { collegeId = Model.College.Id })" class="float-end text-primary">
                    <i class="fas fa-times"></i> Clear search
                </a>
            </div>
        </div>
    </div>
}

<!-- Companies Section -->
<div class="row">
    <div class="col-12 mb-3">
        <h3><i class="fas fa-building"></i> Companies (@Model.Companies.Count)</h3>
        <hr>
    </div>
</div>

@if (Model.Companies.Any())
{
    <div class="row">
        @foreach (var company in Model.Companies)
        {
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card h-100 shadow-sm company-card">
                    <div class="card-body text-center">
                        <div class="company-logo mb-3">
                            @if (!string.IsNullOrEmpty(company.LogoUrl))
                            {
                                <img src="@company.LogoUrl" alt="@company.Name" class="img-fluid" style="max-height: 80px;">
                            }
                            else
                            {
                                <i class="fas fa-building text-primary" style="font-size: 3rem;"></i>
                            }
                        </div>
                        <h5 class="card-title text-primary">@company.Name</h5>
                        <p class="card-text text-muted">@company.Description</p>
                        <div class="mt-auto">
                            <a href="@Url.Action("Questions", "Home", new { collegeId = Model.College.Id, companyId = company.Id })" 
                               class="btn btn-primary">
                                <i class="fas fa-question-circle"></i> View Questions
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    
}
else
{
    <div class="row">
        <div class="col-12">
            <div class="alert alert-info text-center">
                <i class="fas fa-info-circle fa-2x mb-3"></i>
                <h5>No companies found</h5>
                <p>No companies match your current search criteria for this college.</p>
                <a href="@Url.Action("Companies", "Home", new { collegeId = Model.College.Id })" 
                   class="btn btn-primary">
                    <i class="fas fa-refresh"></i> Show All Companies
                </a>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function() {
            // Add hover effects
            $('.company-card').hover(
                function() {
                    $(this).addClass('shadow-lg').removeClass('shadow-sm');
                    $(this).find('.card-body').addClass('bg-light');
                },
                function() {
                    $(this).addClass('shadow-sm').removeClass('shadow-lg');
                    $(this).find('.card-body').removeClass('bg-light');
                }
            );

            // Search form enhancements
            var searchForm = $('form[method="get"]');
            var searchBtn = searchForm.find('button[type="submit"]');
            var originalBtnText = searchBtn.html();

            // Form submission with loading state
            searchForm.on('submit', function() {
                searchBtn.html('<i class="fas fa-spinner fa-spin"></i>&nbsp;Searching...');
                searchBtn.prop('disabled', true);
            });

            // Search on Enter key
            $('#searchTerm').on('keypress', function(e) {
                if (e.which == 13) {
                    searchForm.submit();
                }
            });

            // Highlight search results
            var searchTerm = '@Html.Raw(Model.SearchTerm ?? "")';
            if (searchTerm.length > 0) {
                $('.card-title, .card-text').each(function() {
                    var text = $(this).text();
                    var regex = new RegExp('(' + searchTerm.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
                    $(this).html(text.replace(regex, '<mark>$1</mark>'));
                });
            }
        });
    </script>
}
